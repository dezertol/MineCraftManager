MCM_SECRET_KEY=replace-with-a-long-random-secret
MCM_SERVER_NAME=My Minecraft Server
MCM_CONNECTION_HOST=minecraft.example.com
MCM_CONNECTION_PORT=25565

# Directory containing server.properties, whitelist.json, logs/, world/, and server jar.
MCM_SERVER_DIR=/opt/minecraft/server
MCM_BACKUP_DIR=/opt/minecraft/backups

# Preferred for production control.
MCM_SERVICE_NAME=minecraft.service

# Optional command overrides. If set, quote values because they contain spaces.
# MCM_START_COMMAND="sudo -n systemctl start minecraft.service"
# MCM_STOP_COMMAND="sudo -n systemctl stop minecraft.service"
# MCM_RESTART_COMMAND="sudo -n systemctl restart minecraft.service"
# MCM_UPGRADE_COMMAND=/opt/minecraft/upgrade-server.sh

# Production web service settings used by scripts/install-web-service.sh.
# MCM_WEB_BIND=0.0.0.0:8080
# MCM_WEB_WORKERS=2
